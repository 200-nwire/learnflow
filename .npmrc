# Hoist lib0 (yjs dependency) so Vite can resolve it from root node_modules
public-hoist-pattern[]=lib0
public-hoist-pattern[]=echarts

# Monorepo is mid-refactor (lockfile/manifests drift, disabled @amit/adaptivity).
# Don't enforce a frozen lockfile in CI (Netlify) so the playground can deploy.
frozen-lockfile=false
